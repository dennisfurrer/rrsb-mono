{
  "name": "rrsb-mono",
  "private": true,
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=22.14.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "prisma",
      "esbuild"
    ]
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "db:generate": "pnpm --filter @rrsb/db exec prisma generate",
    "db:migrate": "pnpm --filter @rrsb/db exec prisma migrate dev",
    "db:push": "pnpm --filter @rrsb/db exec prisma db push"
  },
  "devDependencies": {
    "turbo": "^2.8.10",
    "typescript": "^5.9.3"
  }
}
